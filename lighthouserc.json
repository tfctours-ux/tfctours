{
  "$schema": "https://raw.githubusercontent.com/GoogleChrome/lighthouse-ci/main/docs/configuration.md",
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/about",
        "http://localhost:3000/contact",
        "http://localhost:3000/services",
        "http://localhost:3000/services/umrah-packages",
        "http://localhost:3000/services/tour-packages",
        "http://localhost:3000/guides/saudi-visa-guide",
        "http://localhost:3000/tour-calculator",
        "http://localhost:3000/umrah-calculator"
      ],
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":    ["error", { "minScore": 0.85 }],
        "categories:accessibility":  ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo":            ["error", { "minScore": 1.00 }],
        "first-contentful-paint":    ["warn",  { "maxNumericValue": 1800 }],
        "largest-contentful-paint":  ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift":   ["error", { "maxNumericValue": 0.1  }],
        "total-blocking-time":       ["warn",  { "maxNumericValue": 300  }],
        "speed-index":               ["warn",  { "maxNumericValue": 3400 }],
        "uses-text-compression":     "error",
        "uses-responsive-images":    "warn",
        "modern-image-formats":      "warn",
        "render-blocking-resources": "warn",
        "color-contrast":            "error",
        "tap-targets":               "error",
        "image-alt":                 "error",
        "html-has-lang":             "error",
        "html-lang-valid":           "error",
        "hreflang":                  "error",
        "meta-description":          "error",
        "document-title":            "error",
        "canonical":                 "error",
        "structured-data":           "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
